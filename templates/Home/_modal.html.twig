<div class="modal-wrapper" data-controller="player-modal" data-player-modal-game-menu-outlet="#game-menu" data-player-modal-api-url-value="/api/players">
	<div data-player-modal-target="backdrop" data-action="click->player-modal#close" class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm z-40 transition-opacity duration-200"></div>
	<div data-player-modal-target="modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
		<div class="bg-gray-900 border border-gray-700 rounded-2xl shadow-2xl w-full max-w-md p-8">

			<div class="flex items-center justify-between mb-6">
				<h2 class="text-2xl font-black text-white">Choisis ton pseudo</h2>
				<button data-action="click->player-modal#close" class="text-gray-400 hover:text-white transition-colors">
					✕
				</button>
			</div>

			<div class="space-y-4">
				<div>
					<label class="block text-sm text-gray-400 mb-2">Pseudo</label>
					<input type="text" data-player-modal-target="input" data-action="keydown->player-modal#onKeydown input->player-modal#clearError" placeholder="Ex: SuperJoueur42" maxlength="20" class="w-full bg-gray-800 border border-gray-600 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 placeholder-gray-500 transition-colors"/>
					<p data-player-modal-target="error" class="hidden text-rose-400 text-sm mt-2"></p>
				</div>

				<button data-action="click->player-modal#submit" data-player-modal-target="submitBtn" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 rounded-xl transition-colors duration-200 disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2">
					<span data-player-modal-target="btnText">Jouer !</span>
					<span data-player-modal-target="btnLoader" class="hidden">
						<svg class="animate-spin h-4 w-4" fill="none" viewbox="0 0 24 24">
							<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
							<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
						</svg>
					</span>
				</button>
			</div>

		</div>
	</div>
</div>
